# ── Football Probabilistic Analysis Platform ─────────────────────────────────
# Copie para .env e ajuste os valores

PROJECT_NAME="Football Probabilistic Analysis Platform"
VERSION="1.0.0"
DEBUG=false

# Competições suportadas
BRASILEIRAO_NAME=brasileirao
UCL_NAME=champions_league

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Banco de dados
DATABASE_URL=sqlite:///./football_analysis.db

# Treinamento
RANDOM_STATE=42
TEST_SIZE=0.2
VALIDATION_SIZE=0.1
ROLLING_WINDOWS=[3,5,10]
RECENT_FORM_MATCHES=5

# ELO
ELO_K_FACTOR=32.0
ELO_INITIAL_RATING=1500.0
ELO_HOME_ADVANTAGE=100.0

# API-Football (RapidAPI) — https://rapidapi.com/api-sports/api/api-football
# Plano gratuito: 100 requisições/dia
API_FOOTBALL_KEY=677757d29a30bd0bf42a2e14bd43a17d
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Logging
LOG_LEVEL=INFO
